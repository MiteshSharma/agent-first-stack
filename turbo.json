{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": [
        "NODE_ENV",
        "PORT",
        "HOST",
        "DATABASE_URL",
        "DATABASE_SSL",
        "REDIS_URL",
        "JWT_SECRET",
        "CORS_ORIGIN",
        "TYPEORM_SYNCHRONIZE",
        "VITE_API_URL"
      ]
    },
    "clean": {
      "cache": false
    }
  }
}
