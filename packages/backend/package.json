{
  "name": "@agent-first-stack/backend",
  "version": "1.0.0",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsx watch --tsconfig tsconfig.json src/index.ts",
    "lint": "eslint src/ --fix",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.0",
    "@agent-first-stack/shared": "workspace:*",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.43.0",
    "fastify": "^5.2.0",
    "fastify-type-provider-zod": "^5.0.0",
    "ioredis": "^5.4.0",
    "pg": "^8.13.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.31.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.0",
    "typescript": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
